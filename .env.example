# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                      # set to 'production' on Render

# URL of your frontend (no trailing slash)
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────────
# Option A: connection string (Neon / Render Postgres / Railway)
# Takes priority over the individual vars below.
DATABASE_URL=

# Option B: individual vars (local development)
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=HOTEL-DB

# ── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Full absolute URL that Google redirects to after auth.
# Must match exactly what you added in Google Cloud Console → Authorized redirect URIs.
# Local:      http://localhost:3000/api/auth/google/callback
# Production: https://your-api.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars
